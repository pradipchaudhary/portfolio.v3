// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(user)
  createdAt DateTime @default(now())
}

enum Role {
  admin
  user
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String? // detailed markdown/html
  link        String?
  github      String?
  image       String?
  tags        String[] // simple array (fast & practical)

  featured  Boolean @default(false)
  published Boolean @default(true)
  order     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PlatformType {
  GITHUB
  LINKEDIN
  TWITTER
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  DRIBBBLE
  CUSTOM
}

model SocialLink {
  id         String       @id @default(cuid())
  platform   PlatformType @default(CUSTOM)
  name       String // Display label: e.g., "Follow me on GitHub"
  href       String // Full URL validation handled at API level
  icon       String // Icon key for Lucide-react or FontAwesome
  color      String? // Optional Hex code: e.g., "#0077B5" for LinkedIn
  hoverColor String? // Hover state hex code
  order      Int          @default(0)
  isActive   Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order]) // Optimized for fetching the sorted list
}
